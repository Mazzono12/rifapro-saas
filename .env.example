NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://usuario:senha@host:5432/rifapro
STORAGE_DRIVER=postgres

PUBLIC_BASE_URL=https://rifas.seudominio.com.br
ADMIN_BASE_URL=https://admin.seudominio.com.br
CORS_ORIGINS=

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=

ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

JWT_SECRET=gere-um-segredo-forte-com-32-caracteres-ou-mais
SESSION_SECRET=gere-outro-segredo-forte-com-32-caracteres-ou-mais
GATEWAY_CREDENTIALS_ENCRYPTION_KEY=gere-uma-chave-forte-para-credenciais

SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
ALLOW_SUPERADMIN_SEED=false
DEFAULT_TENANT_ID=tenant-principal

ENABLE_PUBLIC_DEBUG=false
ENABLE_TEST_ENDPOINTS=false

